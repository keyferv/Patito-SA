# Secrets
.env
.env.*
!.env.example

# Python environments and caches
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Streamlit local secrets
.streamlit/secrets.toml

# Generated vector stores
vectorstores/infraestructura/*
vectorstores/seguridad/*
vectorstores/incidentes/*
!vectorstores/infraestructura/.gitkeep
!vectorstores/seguridad/.gitkeep
!vectorstores/incidentes/.gitkeep

# Local runtime outputs
outputs/*
!outputs/.gitkeep

# Local logs and OS files
*.log
.DS_Store
Thumbs.db

# Editor and local tool folders
.vscode/
.idea/
.atl/
